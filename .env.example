# 全局
ICS_FILE_NAME=latest
SKIP_HOLIDAY_CALENDAR=true
ENABLE_TENCENT_SYNC=false

# 飞书 Base
APP_ID=
APP_SECRET=
APP_TOKEN=
TABLE_ID=

# 腾讯 CalDAV
TENCENT_ACCOUNT_NAME=腾讯会议日历
TENCENT_USERNAME=
TENCENT_PASSWORD=
TENCENT_URL=https://cal.meeting.tencent.com/caldav/{username}/calendar/
# 兼容别名（如 GitHub Actions secrets）
# TENCENT_CALDAV_USERNAME=
# TENCENT_CALDAV_PASSWORD=
# TENCENT_CALDAV_URL=https://cal.meeting.tencent.com/caldav/{username}/calendar/
TENCENT_SYNC_DAYS_PAST=90
TENCENT_SYNC_DAYS_FUTURE=90

# 飞书 CalDAV
FEISHU_ACCOUNT_NAME=飞书日历
FEISHU_USERNAME=
FEISHU_PASSWORD=
FEISHU_URL=https://caldav.feishu.cn
FEISHU_CALENDAR_URL=
# 兼容别名（如 GitHub Actions secrets）
# FEISHU_CALDAV_USERNAME=
# FEISHU_CALDAV_PASSWORD=
# FEISHU_CALDAV_URL=
FEISHU_SYNC_DAYS_PAST=90
FEISHU_SYNC_DAYS_FUTURE=90

